{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "ConnectionStrings": {
    "Database":  "Server=localhost;Port=5432;Database=directory_service_db;Username=postgres;Password=postgres;"
  },
  "DepartmentCleanup": {
    "IntervalHours": 24,
    "InactiveDaysThreshold": 30
  },
  "LocationCleanup": {
    "IntervalHours": 24,
    "InactiveDaysThreshold": 30
  },
  "RedisOptions": {
    "Configuration": "localhost:6379"
  },
  "CacheOptions": {
    "LocalCacheExpirationMinutes": 5,
    "DistributedCacheExpirationMinutes": 5
  }
}
